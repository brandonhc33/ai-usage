<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.github.brandonhc33.ai-usage</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <name>AI Usage</name>
  <summary>Shows Codex/ChatGPT and Claude usage in the COSMIC topbar</summary>
  <developer id="com.github.brandonhc33">
    <name>Brandon Hernandez Cofre</name>
  </developer>
  <description>
    <p>
      AI Usage is a native COSMIC panel applet that shows how much of your Codex/ChatGPT and
      Claude usage limits you have consumed. It reads a small status file produced by an
      external collector and displays the primary usage percentage in the topbar, with a
      popup showing the detail for both providers.
    </p>
  </description>
  <icon type="remote" width="64" height="64" scale="1">
    https://github.com/brandonhc33/ai-usage-applet/raw/main/resources/icon.svg
  </icon>
  <url type="homepage">https://github.com/brandonhc33/ai-usage-applet</url>
  <url type="vcs-browser">https://github.com/brandonhc33/ai-usage-applet</url>
  <launchable type="desktop-id">com.github.brandonhc33.ai-usage.desktop</launchable>
  <provides>
    <binary>ai-usage-applet</binary>
  </provides>
  <requires>
    <display_length compare="ge">360</display_length>
  </requires>
  <supports>
    <control>keyboard</control>
    <control>pointing</control>
    <control>touch</control>
  </supports>
  <categories>
    <category>Utility</category>
  </categories>
  <keywords>
    <keyword>COSMIC</keyword>
    <keyword>AI</keyword>
    <keyword>Codex</keyword>
    <keyword>Claude</keyword>
  </keywords>
  <content_rating type="oars-1.1" />
</component>
