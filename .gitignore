# Rust build artifacts
.cargo/
*.pdb
**/*.rs.bk
debug/
target/
vendor/
vendor.tar

# Debian packaging helper files (used by `just tag`)
debian/*
!debian/changelog
!debian/control
!debian/copyright
!debian/install
!debian/rules
!debian/source

# Node.js collector dependencies
scripts/node_modules/
npm-debug.log*

# Never commit real usage status, debug captures, or session profiles.
# These live under ~/.cache and ~/.config and are never part of the repo,
# but are ignored here too in case they're generated locally during testing.
status.json
last-good-status.json
codex.json
claude.json
last-error.json
debug-*.txt
profiles/
